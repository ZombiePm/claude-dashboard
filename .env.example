# Server
BIND=0.0.0.0
PORT=8080
USE_SSL=0

# Auth
AUTH_USER=admin
AUTH_PASS=changeme

# Data sources
MEMORY_DIR=/root/MEMORY
HISTORY_FILE=/root/.claude/history.jsonl

# SSL (when USE_SSL=1)
# CERT_FILE=cert.pem
# KEY_FILE=key.pem

# Path normalization (Windows → Linux)
# Format: source=target,source2=target2
# NORM_PATH_MAP=C:/Users/me=/home/me,//server/share=/mnt/share
